# ============================================================================
# DeoDap Care Panel — backend environment.
# Copy this file to `.env` and fill in real values. Everything has a sensible
# default for local dev, so the app + test suite run with an (almost) empty file.
# NEVER commit the real `.env`.
# ============================================================================

# ---- Django core ----
DJANGO_SECRET_KEY=change-this-to-a-long-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=*
DJANGO_TIME_ZONE=Asia/Kolkata
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# ---- Email provider ----
# 'imap' (host + app password, simplest) or 'gmail' (Gmail API OAuth).
EMAIL_PROVIDER=imap

# IMAP (used when EMAIL_PROVIDER=imap). Use an APP PASSWORD for Gmail/Zoho.
#   Zoho India: imap.zoho.in | Gmail: imap.gmail.com | Outlook: outlook.office365.com
IMAP_HOST=imap.zoho.in
IMAP_PORT=993
IMAP_USER=your-mailbox@example.com
IMAP_PASSWORD=your-app-password
IMAP_USE_SSL=True
IMAP_FOLDER=INBOX
IMAP_FETCH_LIMIT=25

# SMTP (outbound replies). Blank SMTP_HOST is derived from IMAP_HOST (imap.* -> smtp.*).
SMTP_HOST=
SMTP_PORT=465
SMTP_USE_SSL=True
SMTP_TIMEOUT=60
# From / Reply-To shown to customers (blank = the IMAP account).
REPLY_FROM=
REPLY_FROM_NAME=DeoDap Support
REPLY_TO=

# ---- Gmail API (only when EMAIL_PROVIDER=gmail) ----
# One Google OAuth client for all brand mailboxes. See Credentials.json.example.
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-google-oauth-client-secret
# Cloud Pub/Sub push topic + shared secret for the webhook (?token=...).
GMAIL_PUBSUB_TOPIC=
GMAIL_PUBSUB_TOKEN=

# ---- AI classifier (pick the provider you use; all optional) ----
# Gemini (https://aistudio.google.com/apikey)
GEMINI_API_KEY=your-gemini-api-key
GEMINI_MODEL=
# Groq (OpenAI-compatible)
GROQ_API_KEY=your-groq-api-key
GROQ_MODEL=llama-3.3-70b-versatile
# OpenAI
OPENAI_API_KEY=your-openai-api-key
OPENAI_MODEL=
# Fall back to deterministic keyword rules when no AI key is configured.
CLASSIFIER_RULE_FALLBACK=True
AI_MAX_RETRIES=3
AI_RETRY_BASE_DELAY=2

# ---- Shopify Admin API (live order/invoice lookup; per-brand overrides win) ----
SHOPIFY_SHOP=your-store.myshopify.com
SHOPIFY_TOKEN=shpat_your_admin_api_token
SHOPIFY_API_VERSION=2024-10

# ---- Courier / shipping portal (live AWB tracking, optional) ----
SHIPPING_BASE_URL=
SHIPPING_API_KEY=
SHIPPING_TRACKING_URL_BASE=https://ship.deodap.in/tracking/

# ---- DeoDap Care Panel integration ----
CARE_PANEL_API_URL=https://care.deodap.info/api/external/care-panel
CARE_PANEL_API_KEY=
# Gallabox store-json (creates the external ticket + tracking hash).
CARE_PANEL_STORE_URL=https://care.deodap.in/api/gallabox/ticket/store-json
CARE_PANEL_TOKEN=
CARE_PANEL_STORE_TOKEN=
CARE_PANEL_STORE_AUTH=bearer
CARE_PANEL_STORE_SOURCE_ID=3
# Shared secret the Care Panel sends to /api/care-panel/webhook (blank = no auth, dev only).
CARE_PANEL_WEBHOOK_TOKEN=your-care-panel-webhook-token
# Optional Care-Panel issue-id overrides (defaults are baked in; see settings.py
# CARE_PANEL_ISSUE_MAP), e.g. CARE_PANEL_PAYMENT_NO_ORDER_ISSUE_ID=12

# Public URL of THIS app, where the /t tracking portal is served (NOT localhost,
# NOT care.deodap.in). Blank = no internal tracking link is added to emails.
PUBLIC_BASE_URL=

# ---- Internal communications ----
# Comma-separated addresses; mail to/cc/bcc any of these skips the support pipeline.
INTERNAL_RECIPIENTS=

# ---- Automation timers ----
AUTO_FETCH_MINUTES=5
WAITING_SWEEP_MINUTES=30
REMINDER_HOURS=24
AUTOCLOSE_HOURS=72
REOPEN_DAYS=7
SEND_TICKET_CONFIRMATIONS=True

# ---- Auth / bootstrap ----
# AUTO_LOGIN opens the panel without a sign-in screen (single-tenant convenience).
AUTO_LOGIN=True
AUTO_LOGIN_USER=admin
DEFAULT_ADMIN_EMAIL=admin@example.com
DEFAULT_ADMIN_PASSWORD=change-me

# ---- Company brochure (attached to franchise/company inquiries, optional) ----
COMPANY_BROCHURE_PATH=
COMPANY_BROCHURE_FILENAME=company_profile.pdf
